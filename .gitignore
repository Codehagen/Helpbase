# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules
.pnp
.pnp.js

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs
.next/
out/
build
dist

# Auto-generated by Next.js — should not be tracked
apps/web/next-env.d.ts


# Debug
npm-debug.log*

# Misc
.DS_Store
*.pem
.gstack/

# Helpbase managed assets (rebuilt from content/ by sync-content-assets)
public/_helpbase-assets/

# Generated docs artifacts for AI agents (rebuilt by generate-llms.mjs on prebuild)
apps/web/public/llms.txt
apps/web/public/llms-full.txt
apps/web/public/_helpbase-assets/
# CLI local state under .helpbase/ — user-specific (slug, session token,
# reservation cache, synthesis artifacts) and must NEVER be committed.
# Skills (.helpbase/skills/*.md) are source-of-truth for the docs team
# and DO get committed — so we ignore the known artifact filenames rather
# than blanket-ignoring the whole directory (gitignore won't re-include
# files from a fully-excluded parent). The ** prefix matches .helpbase/
# at any nesting depth — CLI creates it relative to cwd, so monorepo
# subdirs (apps/web/.helpbase/, etc.) need the same rules.
**/.helpbase/*.json

# Eval harness output — per-run artifact, not committed
packages/cli/eval/eval-report.json
packages/cli/eval/hosted-parity-report.json

# Local agent tooling (not shared)
.agents/
.claude/
skills-lock.json
DEVICE_FLOW_PROMPT.md
NEXT_SESSION_PROMPT.md
