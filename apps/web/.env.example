# -----------------------------------------------------------------------------
# helpbase.dev (apps/web) environment variables
# Copy to .env.local for local development. Real values go in Vercel env.
# -----------------------------------------------------------------------------

# ── Better Auth ──────────────────────────────────────────────────────────────
# Encryption secret for session cookies. Min 32 chars.
#   generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the running web app. In dev, http://localhost:3000.
BETTER_AUTH_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string for the Better Auth tables (user/session/account/
# verification). Uses the same Supabase project as NEXT_PUBLIC_SUPABASE_URL.
#   Supabase dashboard → Project Settings → Database → Connection string
#   Use the "direct" (session) connection, not the pooler — Better Auth's
#   built-in migrations need session-level features that PgBouncer transaction
#   mode doesn't support. For runtime, the pooler is fine; for migrations, use
#   direct.
DATABASE_URL=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Resend API key for transactional emails (magic-link sign-in).
#   get at resend.com/api-keys
# If unset in local dev, magic links are printed to the server console (stderr)
# so you can click them from your terminal without signing up for Resend.
RESEND_API_KEY=

# From-address for sign-in emails. Requires the domain to be verified in Resend.
RESEND_FROM_EMAIL="helpbase <login@auth.helpbase.dev>"

# ── OAuth providers (optional) ───────────────────────────────────────────────
# Both pairs are optional. Set either/both to enable "Continue with Google" /
# "Continue with GitHub" on /device. Buttons render only when both id + secret
# for a provider are present; email magic-link stays available regardless.
#
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID
#   Application type: Web application
#   Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
#   (e.g. https://helpbase.dev/api/auth/callback/google for prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   Homepage URL: {BETTER_AUTH_URL}
#   Authorization callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Supabase (existing — used for tenant content, NOT auth) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Tenant routing ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ROOT_DOMAIN=helpbase.dev

# ── Vercel KV (rate limiting) ────────────────────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=
