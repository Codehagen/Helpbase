{
  "name": "helpbase",
  "version": "0.8.0",
  "description": "CLI for managing your Helpbase help center",
  "type": "module",
  "bin": {
    "helpbase": "dist/index.js"
  },
  "files": [
    "dist",
    "fixtures"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "eval": "tsx eval/runner.ts",
    "typecheck": "tsc --noEmit",
    "mint:token": "node scripts/mint-test-token.mjs",
    "docs:cli": "node scripts/generate-cli-docs.mjs",
    "docs:cli:check": "node scripts/generate-cli-docs.mjs --check"
  },
  "keywords": [
    "helpbase",
    "help-center",
    "cli",
    "documentation",
    "ai"
  ],
  "author": "CodeHagen",
  "license": "AGPL-3.0-only",
  "homepage": "https://helpbase.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codehagen/helpbase.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Codehagen/helpbase/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@supabase/supabase-js": "^2.103.0",
    "ai": "^5.0.0",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "update-notifier": "^7.3.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/update-notifier": "^6.0.8",
    "@workspace/shared": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
