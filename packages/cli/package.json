{
  "name": "helpbase",
  "version": "0.0.1",
  "description": "CLI for managing your Helpbase help center",
  "type": "module",
  "bin": {
    "helpbase": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "helpbase",
    "help-center",
    "cli",
    "documentation",
    "ai"
  ],
  "author": "CodeHagen",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "ai": "^5.0.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@workspace/shared": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "@types/node": "^25.1.0"
  }
}
