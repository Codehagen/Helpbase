# ── Required for the HTTP MCP transport ──────────────────────────────────
# Bearer token that remote agents must present on every request. Generate
# with: openssl rand -hex 32
# If unset, `helpbase mcp start --http` refuses to start (we never ship
# an unauthenticated MCP endpoint).
HELPBASE_MCP_TOKEN=

# Optional: CORS allowlist for browser-based agents. Comma-separated.
# Leave unset to restrict to same-origin + server-to-server requests.
# HELPBASE_MCP_ALLOWED_ORIGINS=https://my-agent.internal.example.com

# ── Optional: AI doc sync ─────────────────────────────────────────────────
# Used by `helpbase sync` and by scheduled doc-sync workflows.
# Get one at https://vercel.com/ai-gateway
# AI_GATEWAY_API_KEY=

# ── Optional: MDX content location ────────────────────────────────────────
# Default: auto-detected (content/ or packages/docs/content/). Override if
# your handbook lives somewhere non-standard.
# HELPBASE_CONTENT_DIR=./content
