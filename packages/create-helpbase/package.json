{
  "name": "create-helpbase",
  "version": "0.2.0",
  "description": "Create a beautiful, AI-powered help center in seconds",
  "type": "module",
  "bin": {
    "create-helpbase": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "internal-overlay"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "help-center",
    "helpbase",
    "documentation",
    "mdx",
    "shadcn",
    "next.js",
    "ai"
  ],
  "author": "CodeHagen",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "ai": "^5.0.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@workspace/shared": "workspace:*",
    "@types/node": "^25.1.0",
    "@workspace/typescript-config": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
