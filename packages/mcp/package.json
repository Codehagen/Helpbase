{
  "name": "@helpbase/mcp",
  "version": "0.0.1",
  "description": "Self-hosted MCP server that exposes your Helpbase docs to AI agents. Runs from your repo, reads your MDX, serves it over the Model Context Protocol.",
  "type": "module",
  "bin": {
    "helpbase-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/server.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "helpbase",
    "mcp",
    "model-context-protocol",
    "docs",
    "ai",
    "knowledge-layer"
  ],
  "author": "CodeHagen",
  "license": "AGPL-3.0-only",
  "homepage": "https://helpbase.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codehagen/helpbase.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/Codehagen/helpbase/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/typescript-config": "workspace:*",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
