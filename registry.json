          "type": "registry:file",
          "target": "mcp/tools/list-skills.ts"
        },
        {
          "path": "registry/helpbase-mcp/tools/get-skill.ts",
          "type": "registry:file",
          "target": "mcp/tools/get-skill.ts"
        },
        {
          "path": "registry/helpbase-mcp/README.md",
          "type": "registry:file",
          "target": "mcp/README.md"
        }
      ]
