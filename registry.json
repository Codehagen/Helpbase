          "type": "registry:file",
          "target": "mcp/tools/search-docs.ts"
        },
        {
          "path": "registry/helpbase-mcp/tools/get-doc.ts",
          "type": "registry:file",
          "target": "mcp/tools/get-doc.ts"
        },
        {
